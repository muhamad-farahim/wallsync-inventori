<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_transaksi_produk"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              orientation="Portrait"
              whenNoDataType="AllSectionsNoDetail">

    <parameter name="periode" class="java.lang.String"/>

    <field name="productName" class="java.lang.String"/>
    <field name="currentStock" class="java.lang.Integer"/>
    <field name="moneyIn" class="java.lang.Long"/>
    <field name="moneyOut" class="java.lang.Long"/>

    <variable name="totalStock" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{currentStock}]]></variableExpression>
    </variable>
    <variable name="totalIn" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{moneyIn}]]></variableExpression>
    </variable>
    <variable name="totalOut" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{moneyOut}]]></variableExpression>
    </variable>
    <variable name="totalNet" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{moneyIn} - $F{moneyOut}]]></variableExpression>
    </variable>

    <title>
        <band height="80" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Laporan Transaksi Per Produk]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="45" width="555" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Periode: " + $P{periode}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="200" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Produk]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="55" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Stok]]></text>
            </staticText>
            <staticText>
                <reportElement x="255" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Uang Masuk]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Uang Keluar]]></text>
            </staticText>
            <staticText>
                <reportElement x="455" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Saldo]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="200" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{productName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="55" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{currentStock}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="255" y="0" width="100" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{moneyIn}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="355" y="0" width="100" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{moneyOut}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="455" y="0" width="100" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{moneyIn} - $F{moneyOut}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="0" y="0" width="277" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Dicetak pada: " + new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="277" y="0" width="200" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER} + " dari "]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement x="477" y="0" width="78" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="200" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Total]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="0" width="55" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{totalStock}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="255" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{totalIn}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="355" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{totalOut}]]></textFieldExpression>
            </textField>
            <textField pattern="Rp #,##0">
                <reportElement x="455" y="0" width="100" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{totalNet}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
