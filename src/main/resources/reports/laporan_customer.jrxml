<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_customer"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              orientation="Portrait"
              whenNoDataType="AllSectionsNoDetail">

    <parameter name="tanggalCetak" class="java.lang.String"/>

    <field name="id" class="java.lang.Long"/>
    <field name="name" class="java.lang.String"/>
    <field name="subdistrict" class="java.lang.String"/>
    <field name="dobLabel" class="java.lang.String"/>
    <field name="joinedLabel" class="java.lang.String"/>

    <variable name="totalCustomers" class="java.lang.Long" calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>

    <title>
        <band height="80" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Laporan Customer]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="45" width="555" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Tanggal Cetak: " + $P{tanggalCetak}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="30" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="30" y="0" width="160" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Nama]]></text>
            </staticText>
            <staticText>
                <reportElement x="190" y="0" width="110" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Domisili]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="140" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Tempat, Tgl Lahir (Umur)]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="115" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                    <bottomPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Bergabung]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="30" height="18"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="30" y="0" width="160" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="190" y="0" width="110" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{subdistrict}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="140" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{dobLabel}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="115" height="18"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{joinedLabel}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="0" y="0" width="277" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Dicetak pada: " + new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="277" y="0" width="200" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER} + " dari "]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement x="477" y="0" width="78" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="300" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Customer]]></text>
            </staticText>
            <textField>
                <reportElement x="300" y="0" width="140" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{totalCustomers} + " orang"]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="440" y="0" width="115" height="22"/>
                <box>
                    <topPen lineWidth="1.0"/>
                </box>
                <textElement/>
            </staticText>
        </band>
    </summary>

</jasperReport>